pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--main block
function _init()
px=64
py=64
dir=0
edir=0
make_player()
make_enemy1()
make_sword()
saddx=0
saddy=0
map()
dead=0
end

function make_player()
psprite=1
px=64
py=64
end



function _update()
move_player()
move_enemy1()
col()
sx=px+saddx
sy=py+saddy
end

function _draw()
cls()
map()
draw_player()
draw_sword()
draw_enemy1()
print(flr(pc))
print(flr(pr))
print(dead)
end

function draw_player()
 spr(psprite+dir,px,py)
end
 
function move_player()
 if (btn(0)) px-=1 dir=0 saddx=-6 saddy=0 --left
 if (btn(1)) px+=1 dir=1 saddx=6  saddy=0 --right
 if (btn(2)) py-=1 dir=2 saddy=-7 saddx=0 --up
 if (btn(3)) py+=1 dir=3 saddy=8  saddx=0 --down 
--the var is short for 'sword add y' not sad daddy :i
--ctrl + scroll :)
end

function make_sword()
ssprite=65
spx=px 
spy=py
end

function draw_sword()
if btn(4) then 
spr(ssprite+dir,sx,sy)
end
end
 

-->8
--enemy 1


function make_enemy1()
esprite=16
ex=100
ey=64
end


function draw_enemy1()
spr(esprite+edir,ex,ey)
end


function move_enemy1()
if px<ex then --left 
ex=ex-0.25
edir=2
elseif px>ex then --right
ex=ex+0.25
edir=3
end

if py<ey then --up
ey=ey-0.25
edir=1

elseif py>ey then --down
ey=ey+0.25
edir=0
end
end
-->8
--collision
--we have been scratching our heads over collision for so fucking long ughhhhh -a



function col()
pc=px/8
pr=py/8

ptp=mget(pc,pr)--find player tile position on map 
--ptp is for 'player tile position' 

ec=ex/8
er=ey/8

--find enemy tile position on map7 


if flr(pc) == flr(ec) then
if flr(pr) == flr(er) then

	dead=1
	
	else
	dead=0
end
end
end

--i dont even fucking care if this is bad atp -a
