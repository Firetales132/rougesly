pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- the fact that debugging has to be done manually pisses me off and is also kinda fun
function _init()
ppos={px,py}
dir=0
edir=0
make_player()
make_enemy1()
make_sword()
saddx=0
saddy=0
end

function make_player()
psprite=1
px=64
py=64
end



function _update()
move_player()
move_enemy1()
end

function _draw()
cls()
draw_player()
draw_sword()
draw_enemy1()
print(ex)
print(ey)
print()
print(px)
print(py)
end

function draw_player()
 spr(psprite+dir,px,py)
end
 
function move_player()
 if (btn(0)) px-=1 dir=0 saddx=-6 saddy=0 --left
 if (btn(1)) px+=1 dir=1 saddx=6  saddy=0 --right
 if (btn(2)) py-=1 dir=2 saddy=-7 saddx=0 --up
 if (btn(3)) py+=1 dir=3 saddy=8  saddx=0 --down 
--the var is short for 'sword add y' not sad daddy :i
--ctrl + scroll :)
end

function make_sword()
ssprite=65
spx=px 
spy=py
end

function draw_sword()
if btn(4) then 
spr(ssprite+dir,px+saddx,py+saddy)
end
end
 

-->8
--enemy 1


function make_enemy1()
esprite=16
ex=100
ey=64
end


function draw_enemy1()
spr(esprite+edir,ex,ey)
end


function move_enemy1()
if px<ex then --left 
ex=ex-0.25
edir=2
elseif px>ex then --right
ex=ex+0.25
edir=3
end

if py<ey then --up
ey=ey-0.25
edir=1

elseif py>ey then --down
ey=ey+0.25
edir=0
end
end
