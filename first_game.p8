pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- the fact that debugging has to be done manually pisses me off and is also kinda fun
function _init()
make_player()
dir=0
make_sword()
end

function make_player()
psprite=1
px=64
py=64
end



function _update()
move_player()
end

function _draw()
cls()
draw_player()
draw_sword()
print(dir)
print(ssprite)
end

function draw_player()
 spr(psprite,px,py)
 end
 
function move_player()
 if (btn(0)) px-=1 dir=0 saddx=-6 --left
 if (btn(1)) px+=1 dir=1 saddx=6 --right
 if (btn(2)) py-=1 dir=2 saddy=0 --up
 if (btn(3)) py+=1 dir=3 saddy=0 --down 
--the var is short for 'sword add y' not sad daddy :i
--ctrl + scroll :)
end

function make_sword()
ssprite=65
spx=px 
spy=py
end

function draw_sword()
if btn(4) then 
spr(ssprite+dir,px+saddx,py)
end
end
 

